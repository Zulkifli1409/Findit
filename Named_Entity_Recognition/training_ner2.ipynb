 "cells": [
  {
   "cell_type": "markdown",
   "id": "intro",
   "metadata": {},
   "source": [
    "# 🏷️ Sovereign-Dispatch — Training Model NER (Named Entity Recognition)\n",
    "\n",
    "**Tujuan:** Ekstrak 3 entitas dari pesan darurat:\n",
    "- `LOC` — Lokasi kejadian (Gampong Lambhuk, Jalan Diponegoro, dst)\n",
    "- `NAME` — Nama pelapor / korban (Pak Rahman, Cut Nurul, dst)\n",
    "- `INJURY` — Jenis cedera / kondisi medis (luka parah, patah tulang, dst)\n",
    "\n",
    "**Base Model:** `cahya/bert-base-indonesian-522M`  \n",
    "**Format Data:** IOB2 (token-level classification)  \n",
    "**Dataset:** `ner_dataset_v2.json` — 1200 kalimat sintetis Bahasa Aceh\n",
    "\n",
    "---\n",
    "### Struktur Notebook\n",
    "1. Install & Import\n",
    "2. Load Dataset IOB2\n",
    "3. Encode Label & Split Data\n",
    "4. Tokenisasi (Word → Subword alignment)\n",
    "5. Training\n",
    "6. Evaluasi (seqeval)\n",
    "7. Simpan Model & Uji Inferensi"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h1",
   "metadata": {},
   "source": ["## 1. Install & Import Library"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "install",
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install transformers datasets seqeval seaborn matplotlib torch -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import os\n",
    "import numpy as np\n",
    "import torch\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "\n",
    "from collections import Counter\n",
    "from sklearn.model_selection import train_test_split\n",
    "from transformers import (\n",
    "    AutoTokenizer,\n",
    "    AutoModelForTokenClassification,\n",
    "    TrainingArguments,\n",
    "    Trainer,\n",
    "    DataCollatorForTokenClassification,\n",
    ")\n",
    "from datasets import Dataset\n",
    "from seqeval.metrics import classification_report as seq_report\n",
    "from seqeval.metrics import f1_score as seq_f1\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "print(f'✅ Device: {device}')\n",
    "if device == 'cuda':\n",
    "    print(f'   GPU: {torch.cuda.get_device_name(0)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h2",
   "metadata": {},
   "source": ["## 2. Load Dataset IOB2"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load-data",
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA_PATH = 'ner_dataset_v2.json'\n",
    "\n",
    "with open(DATA_PATH, 'r', encoding='utf-8') as f:\n",
    "    raw_data = json.load(f)\n",
    "\n",
    "print(f'Total kalimat: {len(raw_data)}')\n",
    "\n",
    "# Statistik label\n",
    "all_labels = [lbl for sent in raw_data for lbl in sent['labels']]\n",
    "label_counts = Counter(all_labels)\n",
    "print()\n",
    "print('Distribusi label IOB2:')\n",
    "for lbl, cnt in sorted(label_counts.items()):\n",
    "    print(f'  {lbl:12s}: {cnt}')\n",
    "\n",
    "# Contoh 3 kalimat\n",
    "print()\n",
    "print('Contoh 3 kalimat pertama:')\n",
    "for sent in raw_data[:3]:\n",
    "    pairs = list(zip(sent['tokens'], sent['labels']))\n",
    "    print('  ', ' '.join(f'{t}|{l}' for t, l in pairs))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "viz-labels",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualisasi distribusi label\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "WARNA = {\n",
    "    'O': '#aaa', 'B-LOC': '#1D9E75', 'I-LOC': '#5DCAA5',\n",
    "    'B-NAME': '#534AB7', 'I-NAME': '#AFA9EC',\n",
    "    'B-INJURY': '#D85A30', 'I-INJURY': '#F0997B',\n",
    "}\n",
    "keys = list(label_counts.keys())\n",
    "vals = [label_counts[k] for k in keys]\n",
    "bars = ax.bar(keys, vals, color=[WARNA.get(k, '#999') for k in keys])\n",
    "ax.set_title('Distribusi Label IOB2')\n",
    "ax.set_ylabel('Jumlah token')\n",
    "for bar, v in zip(bars, vals):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, v + 3, str(v),\n",
    "            ha='center', fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.savefig('ner_label_dist.png', dpi=150)\n",
    "plt.show()\n",
    "print('✅ Plot disimpan: ner_label_dist.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h3",
   "metadata": {},
   "source": ["## 3. Encode Label & Split Data"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "label-encode",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Definisi semua label yang mungkin ─────────────────────────────────────\n",
    "LABEL_LIST = [\n",
    "    'O',\n",
    "    'B-LOC',   'I-LOC',\n",
    "    'B-NAME',  'I-NAME',\n",
    "    'B-INJURY','I-INJURY',\n",
    "]\n",
    "LABEL2ID = {l: i for i, l in enumerate(LABEL_LIST)}\n",
    "ID2LABEL = {i: l for i, l in enumerate(LABEL_LIST)}\n",
    "\n",
    "print('Label mapping:')\n",
    "for lbl, idx in LABEL2ID.items():\n",
    "    print(f'  {idx} → {lbl}')\n",
    "\n",
    "# ── Encode label ke integer ────────────────────────────────────────────────\n",
    "all_tokens = [sent['tokens'] for sent in raw_data]\n",
    "all_ids    = [[LABEL2ID[l] for l in sent['labels']] for sent in raw_data]\n",
    "\n",
    "# ── Stratified split berdasarkan ada/tidaknya entitas ─────────────────────\n",
    "# Buat stratifier: kombinasi entitas yang ada\n",
    "def get_entity_key(label_ids):\n",
    "    lbls = set(ID2LABEL[i] for i in label_ids)\n",
    "    has_loc  = 'B-LOC' in lbls\n",
    "    has_name = 'B-NAME' in lbls\n",
    "    has_inj  = 'B-INJURY' in lbls\n",
    "    return f'{int(has_loc)}{int(has_name)}{int(has_inj)}'\n",
    "\n",
    "strat_keys = [get_entity_key(l) for l in all_ids]\n",
    "\n",
    "indices = list(range(len(all_tokens)))\n",
    "idx_train, idx_temp = train_test_split(\n",
    "    indices, test_size=0.30, stratify=strat_keys, random_state=42)\n",
    "strat_temp = [strat_keys[i] for i in idx_temp]\n",
    "idx_val, idx_test = train_test_split(\n",
    "    idx_temp, test_size=0.50, stratify=strat_temp, random_state=42)\n",
    "\n",
    "print(f'\\nSplit: Train={len(idx_train)} | Val={len(idx_val)} | Test={len(idx_test)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h4",
   "metadata": {},
   "source": [\n",
    "## 4. Tokenisasi — Word → Subword alignment\n",
    "\n",
    "> **Masalah khas NER dengan BERT:** BERT memotong kata menjadi sub-kata (`Lambhuk` → `Lam`, `##bhuk`).  \n",
    "> Label hanya diberikan pada sub-kata **pertama**; sub-kata lanjutan diberi label `-100` agar diabaikan loss function."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "tokenize",
   "metadata": {},
   "outputs": [],
   "source": [
    "MODEL_NAME = 'cahya/bert-base-indonesian-522M'\n",
    "MAX_LEN    = 128\n",
    "\n",
    "print(f'⏳ Memuat tokenizer: {MODEL_NAME} ...')\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
    "print('✅ Tokenizer siap')\n",
    "\n",
    "# Demo: cara alignment bekerja\n",
    "demo_tokens = ['Tulong!', 'aneuk', 'luka', 'parah', 'di', 'Gampong', 'Lambhuk']\n",
    "demo_labels = ['O', 'O', 'B-INJURY', 'I-INJURY', 'O', 'B-LOC', 'I-LOC']\n",
    "\n",
    "enc = tokenizer(demo_tokens, is_split_into_words=True,\n",
    "                return_offsets_mapping=True, truncation=True, max_length=MAX_LEN)\n",
    "print('\\nDemo alignment kata → sub-kata:')\n",
    "print(f'{\"Sub-kata\":15s} {\"word_id\":8s} {\"Label asli\":12s} {\"Label assigned\"}')\n",
    "for sub, wid in zip(tokenizer.convert_ids_to_tokens(enc['input_ids']),\n",
    "                    enc.word_ids()):\n",
    "    if wid is None:\n",
    "        lbl_asli = '-'\n",
    "        lbl_asgn = 'SKIP (-100)'\n",
    "    else:\n",
    "        lbl_asli = demo_labels[wid]\n",
    "        # Cek apakah ini sub-kata lanjutan (bukan kata pertama)\n",
    "        prev_wid = enc.word_ids()[enc.word_ids().index(wid) - 1] if enc.word_ids().index(wid) > 0 else None\n",
    "        lbl_asgn = lbl_asli if prev_wid != wid else 'SKIP (-100)'\n",
    "    print(f'{sub:15s} {str(wid):8s} {lbl_asli:12s} {lbl_asgn}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "tokenize-fn",
   "metadata": {},
   "outputs": [],
   "source": [
    "def tokenize_and_align(tokens_list, labels_list):\n",
    "    \"\"\"\n",
    "    Tokenisasi word-level → subword-level dengan alignment label IOB2.\n",
    "    Sub-kata lanjutan (##xxx) mendapat label -100 agar diabaikan loss.\n",
    "    \"\"\"\n",
    "    enc = tokenizer(\n",
    "        tokens_list,\n",
    "        is_split_into_words=True,\n",
    "        padding='max_length',\n",
    "        truncation=True,\n",
    "        max_length=MAX_LEN,\n",
    "    )\n",
    "    aligned_labels = []\n",
    "    word_ids = enc.word_ids()\n",
    "    prev_word_id = None\n",
    "    for word_id in word_ids:\n",
    "        if word_id is None:\n",
    "            # [CLS] / [SEP] / padding → abaikan\n",
    "            aligned_labels.append(-100)\n",
    "        elif word_id != prev_word_id:\n",
    "            # Sub-kata PERTAMA dari sebuah kata → pakai label asli\n",
    "            aligned_labels.append(labels_list[word_id])\n",
    "        else:\n",
    "            # Sub-kata LANJUTAN → abaikan\n",
    "            aligned_labels.append(-100)\n",
    "        prev_word_id = word_id\n",
    "    enc['labels'] = aligned_labels\n",
    "    return enc\n",
    "\n",
    "def make_ner_dataset(indices):\n",
    "    rows = {'input_ids': [], 'attention_mask': [], 'token_type_ids': [], 'labels': []}\n",
    "    for i in indices:\n",
    "        enc = tokenize_and_align(all_tokens[i], all_ids[i])\n",
    "        rows['input_ids'].append(enc['input_ids'])\n",
    "        rows['attention_mask'].append(enc['attention_mask'])\n",
    "        rows['token_type_ids'].append(enc.get('token_type_ids', [0]*MAX_LEN))\n",
    "        rows['labels'].append(enc['labels'])\n",
    "    return Dataset.from_dict(rows)\n",
    "\n",
    "print('⏳ Tokenisasi dataset ...')\n",
    "train_ds = make_ner_dataset(idx_train)\n",
    "val_ds   = make_ner_dataset(idx_val)\n",
    "test_ds  = make_ner_dataset(idx_test)\n",
    "print('✅ Tokenisasi selesai')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h5",
   "metadata": {},
   "source": ["## 5. Training"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "model-load",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f'⏳ Memuat model: {MODEL_NAME} ...')\n",
    "model = AutoModelForTokenClassification.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    num_labels=len(LABEL_LIST),\n",
    "    id2label=ID2LABEL,\n",
    "    label2id=LABEL2ID,\n",
    "    ignore_mismatched_sizes=True,\n",
    ")\n",
    "print(f'✅ Model siap  (num_labels={len(LABEL_LIST)})')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "compute-metrics",
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_metrics(eval_pred):\n",
    "    \"\"\"\n",
    "    Evaluasi NER menggunakan seqeval — metrik standar NLP untuk NER.\n",
    "    Mengonversi prediksi flat → format kalimat untuk seqeval.\n",
    "    \"\"\"\n",
    "    logits, labels = eval_pred\n",
    "    preds = np.argmax(logits, axis=-1)\n",
    "\n",
    "    true_labels, true_preds = [], []\n",
    "    for pred_seq, label_seq in zip(preds, labels):\n",
    "        sent_true, sent_pred = [], []\n",
    "        for p, l in zip(pred_seq, label_seq):\n",
    "            if l == -100:\n",
    "                continue  # skip [CLS], [SEP], sub-kata lanjutan\n",
    "            sent_true.append(ID2LABEL[l])\n",
    "            sent_pred.append(ID2LABEL[p])\n",
    "        true_labels.append(sent_true)\n",
    "        true_preds.append(sent_pred)\n",
    "\n",
    "    return {\n",
    "        'f1': seq_f1(true_labels, true_preds, average='micro'),\n",
    "    }"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Data collator khusus NER: padding label juga di-handle\n",
    "data_collator = DataCollatorForTokenClassification(tokenizer=tokenizer)\n",
    "\n",
    "training_args = TrainingArguments(\n",
    "    output_dir                  = './hasil_training_ner',\n",
    "    num_train_epochs            = 15,\n",
    "    per_device_train_batch_size = 16,\n",
    "    per_device_eval_batch_size  = 32,\n",
    "    warmup_steps                = 50,\n",
    "    weight_decay                = 0.01,\n",
    "    learning_rate               = 3e-5,\n",
    "    eval_strategy               = 'epoch',   # ✅ kompatibel transformers >= 4.41\n",
    "    save_strategy               = 'epoch',\n",
    "    load_best_model_at_end      = True,\n",
    "    metric_for_best_model       = 'f1',\n",
    "    greater_is_better           = True,\n",
    "    logging_dir                 = './logs_ner',\n",
    "    logging_steps               = 30,\n",
    "    fp16                        = (device == 'cuda'),\n",
    "    report_to                   = 'none',\n",
    ")\n",
    "\n",
    "trainer = Trainer(\n",
    "    model           = model,\n",
    "    args            = training_args,\n",
    "    train_dataset   = train_ds,\n",
    "    eval_dataset    = val_ds,\n",
    "    tokenizer       = tokenizer,\n",
    "    data_collator   = data_collator,\n",
    "    compute_metrics = compute_metrics,\n",
    ")\n",
    "\n",
    "print('🚀 Mulai training NER ...')\n",
    "trainer.train()\n",
    "print('✅ Training selesai!')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h6",
   "metadata": {},
   "source": ["## 6. Evaluasi (seqeval)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eval",
   "metadata": {},
   "outputs": [],
   "source": [
    "preds_output = trainer.predict(test_ds)\n",
    "logits = preds_output.predictions\n",
    "labels = preds_output.label_ids\n",
    "preds  = np.argmax(logits, axis=-1)\n",
    "\n",
    "# Rekonstruksi kalimat untuk seqeval\n",
    "true_labels, true_preds = [], []\n",
    "for pred_seq, label_seq in zip(preds, labels):\n",
    "    sent_true, sent_pred = [], []\n",
    "    for p, l in zip(pred_seq, label_seq):\n",
    "        if l == -100:\n",
    "            continue\n",
    "        sent_true.append(ID2LABEL[l])\n",
    "        sent_pred.append(ID2LABEL[p])\n",
    "    true_labels.append(sent_true)\n",
    "    true_preds.append(sent_pred)\n",
    "\n",
    "print('=' * 60)\n",
    "print('📊 HASIL EVALUASI NER — TEST SET')\n",
    "print('=' * 60)\n",
    "print(seq_report(true_labels, true_preds, digits=4))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "h7",
   "metadata": {},
   "source": ["## 7. Simpan Model & Uji Inferensi"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "save",
   "metadata": {},
   "outputs": [],
   "source": [
    "SAVE_DIR = './model_ner2'\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)\n",
    "\n",
    "trainer.save_model(SAVE_DIR)\n",
    "tokenizer.save_pretrained(SAVE_DIR)\n",
    "\n",
    "with open(f'{SAVE_DIR}/label_map.json', 'w') as f:\n",
    "    json.dump({'label2id': LABEL2ID, 'id2label': ID2LABEL}, f, indent=2)\n",
    "\n",
    "print(f'✅ Model disimpan di: {SAVE_DIR}/')\n",
    "print(f'   File: {os.listdir(SAVE_DIR)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "infer",
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import pipeline\n",
    "\n",
    "ner_pipe = pipeline(\n",
    "    'ner',\n",
    "    model=SAVE_DIR,\n",
    "    tokenizer=SAVE_DIR,\n",
    "    aggregation_strategy='simple',  # gabungkan B-/I- jadi satu entitas\n",
    "    device=0 if device == 'cuda' else -1,\n",
    ")\n",
    "\n",
    "pesan_uji = [\n",
    "    \"Tulong! Pak Rahman di Gampong Lambhuk aneuk luka parah!\",\n",
    "    \"Tlg klg sy terjebak di Desa Lamteumen, ada patah tulang!\",\n",
    "    \"Darurat! Cut Nurul pingsan di Jalan Diponegoro!\",\n",
    "    \"Na ureung luka berat di Krueng Aceh, segera bantu!\",\n",
    "]\n",
    "\n",
    "EMOJI = {'LOC': '📍', 'NAME': '👤', 'INJURY': '🩸'}\n",
    "\n",
    "print('🧪 UJI COBA INFERENSI NER:')\n",
    "print('-' * 70)\n",
    "for pesan in pesan_uji:\n",
    "    hasil = ner_pipe(pesan)\n",
    "    print(f'Pesan : {pesan}')\n",
    "    if hasil:\n",
    "        for ent in hasil:\n",
    "            grp   = ent['entity_group']\n",
    "            word  = ent['word']\n",
    "            score = ent['score']\n",
    "            emoji = EMOJI.get(grp, '?')\n",
    "            print(f'  {emoji} [{grp}] \"{word}\" ({score:.2%})')\n",
    "    else:\n",
    "        print('  (tidak ada entitas terdeteksi)')\n",
    "    print()"
   ]
  }
 ]
}
